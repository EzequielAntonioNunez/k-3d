{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "semicolons": "asNeeded"
    }
  },
  "overrides": [
    {
      "includes": ["**/styles/global.css"],
      "linter": { "rules": { "complexity": { "noImportantStyles": "off" } } }
    },
    {
      "includes": ["**/styles/app.css"],
      "linter": { "rules": { "suspicious": { "noDuplicateProperties": "off" } } }
    }
  ]
}
